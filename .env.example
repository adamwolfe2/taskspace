# Database Configuration (Vercel Postgres)
# Get these from your Vercel Postgres dashboard
POSTGRES_URL=postgres://user:password@host:5432/database?sslmode=require
POSTGRES_PRISMA_URL=postgres://user:password@host:5432/database?sslmode=require&pgbouncer=true&connect_timeout=15
POSTGRES_URL_NON_POOLING=postgres://user:password@host:5432/database?sslmode=require
POSTGRES_USER=your_user
POSTGRES_HOST=your_host
POSTGRES_PASSWORD=your_password
POSTGRES_DATABASE=your_database

# Token Encryption Key (REQUIRED for production - encrypts OAuth tokens at rest)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# CRITICAL: Store this securely and never commit it to version control
# If you lose this key, all encrypted tokens will be unrecoverable
TOKEN_ENCRYPTION_KEY=your_base64_encoded_32_byte_key

# Optional: Migration endpoint protection
# Set this to protect the /api/db/migrate endpoint
MIGRATION_KEY=your_secret_migration_key

# Email Configuration (required - for sending invitations and notifications)
# Resend API - Get your API key from https://resend.com
# 1. Sign up at resend.com
# 2. Add and verify your domain (trytaskspace.com)
# 3. Create an API key
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=Taskspace <team@collectivecapital.com>
ADMIN_EMAIL=team@collectivecapital.com

# Application URL (for invitation links and emails)
NEXT_PUBLIC_APP_URL=https://www.trytaskspace.com

# Admin Operations Secret (REQUIRED for production - protects /api/admin/* routes)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Pass as X-Admin-Secret header when calling admin endpoints in production
ADMIN_OPS_SECRET=your_admin_ops_secret_here

# Cron Job Secret (REQUIRED for production - protects cron endpoints)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Set this same value in your Vercel cron job configuration
CRON_SECRET=your_cron_secret_here

# Claude AI Configuration (for AI Command Center features)
# Get your API key from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Asana Integration (optional - for two-way task sync)
# Get your Personal Access Token from https://app.asana.com/0/my-apps
ASANA_ACCESS_TOKEN=your_asana_personal_access_token
ASANA_DEFAULT_PROJECT_ID=your_asana_project_id
# Webhook signature verification (set when creating Asana webhooks)
ASANA_WEBHOOK_SECRET=your_asana_webhook_secret

# Stripe Billing (required for paid plans)
# Get these from https://dashboard.stripe.com
STRIPE_SECRET_KEY=sk_test_xxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# Stripe Price IDs (from your Stripe products)
NEXT_PUBLIC_STRIPE_PRICE_TEAM_MONTHLY=price_xxxxx
NEXT_PUBLIC_STRIPE_PRICE_TEAM_YEARLY=price_xxxxx
NEXT_PUBLIC_STRIPE_PRICE_BUSINESS_MONTHLY=price_xxxxx
NEXT_PUBLIC_STRIPE_PRICE_BUSINESS_YEARLY=price_xxxxx

# Optional: AI Credit Add-on Packs
NEXT_PUBLIC_STRIPE_PRICE_AI_500=price_xxxxx
NEXT_PUBLIC_STRIPE_PRICE_AI_2000=price_xxxxx
NEXT_PUBLIC_STRIPE_PRICE_AI_5000=price_xxxxx

# Stripe Payment Links (direct checkout URLs for marketing/public pages)
NEXT_PUBLIC_STRIPE_LINK_TEAM_MONTHLY=https://buy.stripe.com/xxxxx
NEXT_PUBLIC_STRIPE_LINK_TEAM_YEARLY=https://buy.stripe.com/xxxxx
NEXT_PUBLIC_STRIPE_LINK_BUSINESS_MONTHLY=https://buy.stripe.com/xxxxx
NEXT_PUBLIC_STRIPE_LINK_BUSINESS_YEARLY=https://buy.stripe.com/xxxxx
NEXT_PUBLIC_STRIPE_LINK_AI_500=https://buy.stripe.com/xxxxx
NEXT_PUBLIC_STRIPE_LINK_AI_2000=https://buy.stripe.com/xxxxx
NEXT_PUBLIC_STRIPE_LINK_AI_5000=https://buy.stripe.com/xxxxx

# Slack Integration (optional - for notifications and webhooks)
# Get your signing secret from Slack app settings
SLACK_SIGNING_SECRET=your_slack_signing_secret

# Logging Configuration
LOG_LEVEL=info

# Sentry Error Tracking (optional - recommended for production)
# Set up at https://sentry.io
SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=taskspace

# ============================================
# SETUP INSTRUCTIONS
# ============================================
# 1. Create a Vercel Postgres database at https://vercel.com/docs/storage/vercel-postgres
# 2. Copy the connection strings from Vercel dashboard to the POSTGRES_* variables above
# 3. Deploy to Vercel or run locally with `npm run dev`
# 4. Visit /api/db/migrate to initialize the database tables
# 5. Visit /api/health to verify everything is working
# 6. Create your account at the registration page
