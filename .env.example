# Database Configuration (Vercel Postgres)
# Get these from your Vercel Postgres dashboard
POSTGRES_URL=postgres://user:password@host:5432/database?sslmode=require
POSTGRES_PRISMA_URL=postgres://user:password@host:5432/database?sslmode=require&pgbouncer=true&connect_timeout=15
POSTGRES_URL_NON_POOLING=postgres://user:password@host:5432/database?sslmode=require
POSTGRES_USER=your_user
POSTGRES_HOST=your_host
POSTGRES_PASSWORD=your_password
POSTGRES_DATABASE=your_database

# Optional: Migration endpoint protection
# Set this to protect the /api/db/migrate endpoint
MIGRATION_KEY=your_secret_migration_key

# Email Configuration (optional - for sending invitations and notifications)
# Resend API (recommended) - Get your API key from https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=AIMS Dashboard <noreply@yourdomain.com>
ADMIN_EMAIL=admin@yourdomain.com

# Application URL (for invitation links and emails)
NEXT_PUBLIC_APP_URL=https://your-app-url.vercel.app

# Claude AI Configuration (for AI Command Center features)
# Get your API key from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================
# SETUP INSTRUCTIONS
# ============================================
# 1. Create a Vercel Postgres database at https://vercel.com/docs/storage/vercel-postgres
# 2. Copy the connection strings from Vercel dashboard to the POSTGRES_* variables above
# 3. Deploy to Vercel or run locally with `npm run dev`
# 4. Visit /api/db/migrate to initialize the database tables
# 5. Visit /api/health to verify everything is working
# 6. Create your account at the registration page
